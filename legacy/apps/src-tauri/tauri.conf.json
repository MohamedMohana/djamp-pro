{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "DJANGOForge",
    "version": "0.1.0"
  },
    "tauri": {
    "allowlist": {
      "all": true
    },
      "fs": {
        "all": true,
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "createDir": true,
        "removeDir": true,
        "copyFile": true,
        "moveFile": true,
        "removeFile": true,
        "exists": true,
        "scope": ["$HOME/.djamp/**", "$HOME/djamp-projects/**", "$HOME/djamp-venvs/**", "/tmp/**"]
      },
      "process": {
        "all": false,
        "relaunch": true,
        "exit": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Developer Tool",
      "copyright": "2024 DJANGOForge Team",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "identifier": "com.djangoforge.app",
      "longDescription": "Local Django Development Environment Manager - Transform your Django development with automated domain management, trusted HTTPS certificates, bundled databases and seamless project orchestration.",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "Django Development Environment Manager",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "DJANGOForge - Django Development Manager",
        "width": 1400,
        "minWidth": 1200,
        "minHeight": 700
      }
    ]
  }
}
